{"file":"ToastNotifications-CIWmlby1.js","mappings":";;;;;;;;AAsCA,UAAM,KAAK,WAAA;;+BArCT,CAiCWA,WAAA;;sBAzBaC,MAAA,EAAA,EAAG,QAAM,CAAlB,UAAK;kMAIX,cAAY,MAAM,OAAO,8FAIrBC,eAAA,MAAM,SAAI,YAAA,MAAuB,MAAM,SAAI,UAAA,MAAA,IAAA,wFAGgBA,eAAA,MAAM,OAAO,gFAI1E,cAAU,YAAc,MAAM,OAAO,EAAA;;;;;;;;;;;;;;","names":["_push","_unref","_ssrInterpolate"],"sources":["../../../../components/organisms/ToastNotifications.vue"],"sourcesContent":["<template>\n  <Teleport to=\"body\">\n    <div\n      class=\"fixed bottom-4 right-4 z-[200] flex flex-col gap-2 pointer-events-none\"\n      aria-live=\"polite\"\n      aria-label=\"Notifications\"\n    >\n      <TransitionGroup name=\"toast\">\n        <div\n          v-for=\"toast in ui.toasts\"\n          :key=\"toast.id\"\n          class=\"pointer-events-auto flex items-start gap-3 min-w-[280px] max-w-xs bg-white rounded-xl shadow-modal border border-border-gray px-4 py-3\"\n          role=\"alert\"\n          :aria-label=\"toast.message\"\n        >\n          <!-- Icon -->\n          <span class=\"text-lg shrink-0 mt-0.5\" aria-hidden=\"true\">\n            {{ toast.type === 'success' ? '✅' : toast.type === 'error' ? '❌' : 'ℹ️' }}\n          </span>\n          <!-- Message -->\n          <p class=\"text-sm font-ui text-charcoal flex-1 leading-snug\">{{ toast.message }}</p>\n          <!-- Close -->\n          <button\n            class=\"text-mid-gray hover:text-charcoal shrink-0\"\n            :aria-label=\"`Dismiss: ${toast.message}`\"\n            @click=\"ui.removeToast(toast.id)\"\n          >\n            <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\n            </svg>\n          </button>\n        </div>\n      </TransitionGroup>\n    </div>\n  </Teleport>\n</template>\n\n<script setup lang=\"ts\">\nconst ui = useUIStore()\n</script>\n\n<style scoped>\n.toast-enter-active { transition: all 0.3s ease; }\n.toast-leave-active { transition: all 0.3s ease; }\n.toast-enter-from { opacity: 0; transform: translateX(100%) scale(0.9); }\n.toast-leave-to { opacity: 0; transform: translateX(100%) scale(0.9); }\n.toast-move { transition: transform 0.3s ease; }\n</style>\n"],"version":3}