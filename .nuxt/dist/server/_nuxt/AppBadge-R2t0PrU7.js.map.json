{"file":"AppBadge-R2t0PrU7.js","mappings":";;AAgBA,MAAM,cAAc;;;;;;;;;AAJpB,UAAM,QAAQ;AAMd,UAAM,iBAAiB,SAAS,MAAM;AACpC,cAAQ,MAAM,SAAA;AAAA,QACZ,KAAK;AACH,iBAAO;AAAA,QACT,KAAK;AACH,iBAAO;AAAA,QACT,KAAK;AACH,iBAAO;AAAA,QACT,KAAK;AACH,iBAAO;AAAA,QACT;AACE,iBAAO;AAAA,MAAA;AAAA,IAEb,CAAC;;;QA9BQ,OAAK,CAAG,aAAaA,MAAA,cAAA,CAAc;AAAA,QAAG,MAAK;AAAA,QAAU,cAAY,QAAA;AAAA,MAAA;;gCAC7D,QAAA,KAAK,CAAA,EAAA;AAAA;;;;;;;;;;;","names":["_unref"],"sources":["../../../../components/atoms/AppBadge.vue"],"sourcesContent":["<template>\r\n  <span :class=\"[baseClasses, variantClasses]\" role=\"status\" :aria-label=\"label\">\r\n    <slot>{{ label }}</slot>\r\n  </span>\r\n</template>\r\n\r\n<script setup lang=\"ts\">\r\ninterface Props {\r\n  label?: string\r\n  variant?: 'sale' | 'new' | 'bestseller' | 'trending' | 'default'\r\n}\r\n\r\nconst props = withDefaults(defineProps<Props>(), {\r\n  variant: 'default',\r\n})\r\n\r\nconst baseClasses = 'inline-flex items-center text-[10px] font-ui font-semibold px-2 py-0.5 rounded uppercase tracking-wider'\r\n\r\nconst variantClasses = computed(() => {\r\n  switch (props.variant) {\r\n    case 'sale':\r\n      return 'bg-red-500 text-white'\r\n    case 'new':\r\n      return 'bg-deep-plum text-white'\r\n    case 'bestseller':\r\n      return 'bg-soft-gold text-white'\r\n    case 'trending':\r\n      return 'bg-dusty-rose text-white'\r\n    default:\r\n      return 'bg-charcoal text-white'\r\n  }\r\n})\r\n</script>\r\n"],"version":3}