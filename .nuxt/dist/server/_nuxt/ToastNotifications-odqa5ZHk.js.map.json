{"file":"ToastNotifications-odqa5ZHk.js","mappings":";;;;;;;;AAsCA,UAAM,KAAK,WAAA;;+BArCT,CAiCWA,WAAA;;sBAzBaC,MAAA,EAAA,EAAG,QAAM,CAAlB,UAAK;kMAIX,cAAY,MAAM,OAAO,8FAIrBC,eAAA,MAAM,SAAI,YAAA,MAAuB,MAAM,SAAI,UAAA,MAAA,IAAA,wFAGgBA,eAAA,MAAM,OAAO,gFAI1E,cAAU,YAAc,MAAM,OAAO,EAAA;;;;;;;;;;;;;;","names":["_push","_unref","_ssrInterpolate"],"sources":["../../../../components/organisms/ToastNotifications.vue"],"sourcesContent":["<template>\r\n  <Teleport to=\"body\">\r\n    <div\r\n      class=\"fixed bottom-4 right-4 z-[200] flex flex-col gap-2 pointer-events-none\"\r\n      aria-live=\"polite\"\r\n      aria-label=\"Notifications\"\r\n    >\r\n      <TransitionGroup name=\"toast\">\r\n        <div\r\n          v-for=\"toast in ui.toasts\"\r\n          :key=\"toast.id\"\r\n          class=\"pointer-events-auto flex items-start gap-3 min-w-[280px] max-w-xs bg-white rounded-xl shadow-modal border border-border-gray px-4 py-3\"\r\n          role=\"alert\"\r\n          :aria-label=\"toast.message\"\r\n        >\r\n          <!-- Icon -->\r\n          <span class=\"text-lg shrink-0 mt-0.5\" aria-hidden=\"true\">\r\n            {{ toast.type === 'success' ? '✅' : toast.type === 'error' ? '❌' : 'ℹ️' }}\r\n          </span>\r\n          <!-- Message -->\r\n          <p class=\"text-sm font-ui text-charcoal flex-1 leading-snug\">{{ toast.message }}</p>\r\n          <!-- Close -->\r\n          <button\r\n            class=\"text-mid-gray hover:text-charcoal shrink-0\"\r\n            :aria-label=\"`Dismiss: ${toast.message}`\"\r\n            @click=\"ui.removeToast(toast.id)\"\r\n          >\r\n            <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\r\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\r\n            </svg>\r\n          </button>\r\n        </div>\r\n      </TransitionGroup>\r\n    </div>\r\n  </Teleport>\r\n</template>\r\n\r\n<script setup lang=\"ts\">\r\nconst ui = useUIStore()\r\n</script>\r\n\r\n<style scoped>\r\n.toast-enter-active { transition: all 0.3s ease; }\r\n.toast-leave-active { transition: all 0.3s ease; }\r\n.toast-enter-from { opacity: 0; transform: translateX(100%) scale(0.9); }\r\n.toast-leave-to { opacity: 0; transform: translateX(100%) scale(0.9); }\r\n.toast-move { transition: transform 0.3s ease; }\r\n</style>\r\n"],"version":3}